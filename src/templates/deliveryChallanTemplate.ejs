<!-- src/templates/deliveryChallanTemplate.ejs -->

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <title>Delivery Challan</title>

    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 25px;
        font-family: Arial, sans-serif;
        color: #222;
        position: relative;
      }

      .watermark {
        position: absolute;
        top: 35%;
        left: 50%;
        transform: translate(-50%, -50%);
        opacity: 0.05;
        width: 450px;
        z-index: 0;
      }

      .container {
        position: relative;
        z-index: 2;
      }

      .top-logo {
        text-align: center;
        margin-bottom: 8px;
      }

      .company-box {
        background: #666;
        color: white;
        padding: 8px 20px;
        display: inline-block;
        font-size: 30px;
        letter-spacing: 2px;
        font-weight: 300;
      }

      .company-details {
        text-align: center;
        font-size: 13px;
        line-height: 1.5;
        margin-top: 8px;
      }

      .gst {
        font-weight: bold;
        margin-top: 3px;
      }

      .title {
        text-align: center;
        font-size: 40px;
        font-weight: bold;
        margin: 18px 0;
      }

      .top-section {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
        margin-bottom: 25px;
      }

      .left-section,
      .right-section {
        width: 48%;
        font-size: 15px;
        line-height: 1.8;
      }

      .summary {
        margin-top: 20px;
        margin-bottom: 20px;
        font-size: 16px;
        line-height: 1.8;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
        font-size: 14px;
      }

      table th,
      table td {
        border: 1px solid #555;
        padding: 10px 6px;
        text-align: center;
      }

      table th {
        background: #f2f2f2;
      }

      .footer {
        margin-top: 120px;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
      }

      .receiver {
        width: 45%;
      }

      .receiver-sign {
        margin-bottom: 40px;
      }

      .signature-line {
        border-top: 1px solid #000;
        width: 200px;
        margin-top: 10px;
      }

      .authorized {
        width: 45%;
        text-align: center;
      }

      .authorized-box {
        background: #666;
        color: white;
        display: inline-block;
        padding: 6px 18px;
        font-size: 18px;
        margin-bottom: 25px;
      }

      .page-number {
        position: absolute;
        bottom: 10px;
        right: 20px;
        font-size: 12px;
      }
    </style>
  </head>

  <body>
    <!-- WATERMARK -->
    <img
      src="https://upload.wikimedia.org/wikipedia/commons/thumb/3/36/Logo.svg/512px-Logo.svg.png"
      class="watermark"
    />

    <div class="container">
      <!-- HEADER -->
      <div class="top-logo">
        <div class="company-box">
          SHREE TRADING COMPANY
        </div>

        <div class="company-details">
          Stockist & Traders of HR, CR, GP Sheet,
          MS Plates, Structural <br />

          Material and Expert Profile Cutters
          <br />

          Sr. no. 99, Plot no. 8, Yashwant Nagar
          Chowk, Talco-Bhosari Road, Pune-18.
          <br />

          Email:
          shreetradingunit2@gmail.com | Mobile no:
          +91 8530022333

          <div class="gst">
            GST Number: 27ACBFS4283Q1ZP
          </div>
        </div>
      </div>

      <!-- TITLE -->
      <div class="title">
        DELIVERY CHALLAN
      </div>

      <!-- TOP INFO -->
      <div class="top-section">
        <div class="left-section">
          <div>
            <strong>To:</strong>
            <%= order.customer?.customerName ||
            order.customer?.name %>
          </div>

          <div>
            <strong>Date:</strong>
            <%= new
            Date(currentDate).toLocaleDateString() %>
          </div>

          <div>
            <strong>PO No :</strong>
            <%= order.poNumber || "-" %>
          </div>
        </div>

        <div class="right-section">
          <div>
            <strong>Challan Number:</strong>
            <%= challanNo %>
          </div>

          <div>
            <strong>Transport :</strong>
            <%= vehicleNumber %>
          </div>
        </div>
      </div>

      <!-- SUMMARY -->
      <div class="summary">
        <div>
          <strong>Total Weight:</strong>
          <%= totalWeight.toFixed(2) %> kg
        </div>

        <div>
          <strong>Total CNC Rate:</strong>
          ₹ <%= totalRate.toFixed(2) %>
        </div>
      </div>

      <!-- TABLE -->
      <table>
        <thead>
          <tr>
            <th>W/O NO.</th>
            <th>PART NO.</th>
            <th>T</th>
            <th>L</th>
            <th>W</th>
            <th>QTY</th>
            <th>WEIGHT</th>
            <th>RATE / KG</th>
            <th>RATE / PCS</th>
          </tr>
        </thead>

        <tbody>
          <% items.forEach((item) => { %>
          <tr>
            <td>
              <%= item.programNo || "-" %>
            </td>

            <td>
              <%= item.partNo || "-" %>
            </td>

            <td>
              <%= item.thickness %>
            </td>

            <td>
              <%= item.length %>
            </td>

            <td>
              <%= item.width %>
            </td>

            <td>
              <%= item.qty %>
            </td>

            <td>
              <%= item.weight %>
            </td>

            <td>
              <%= item.ratePerKg || "-" %>
            </td>

            <td>
              ₹
              <%= Number(item.amount || 0).toFixed(2)
              %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>

      <!-- FOOTER -->
      <div class="footer">
        <!-- RECEIVER -->
        <div class="receiver">
          <div class="receiver-sign">
            Receiver's Signature:
          </div>

          <div class="signature-line"></div>

          <div style="margin-top: 20px">
            Mobile no:
          </div>
        </div>

        <!-- AUTHORIZED -->
        <div class="authorized">
          <div class="authorized-box">
            SHREE TRADING COMPANY
          </div>

          <div>
            Authorized Signature
          </div>
        </div>
      </div>

      <div class="page-number">1</div>
    </div>
  </body>
</html>